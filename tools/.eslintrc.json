{
  "env": {
    "node": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "indent": "off",
    "comma-dangle": "off"
  },
  "overrides": [
    {
      "files": ["demos/**/*.spec.js"],
      "env": {
        "node": true,
        "browser": true
      }
    }
  ]
}
